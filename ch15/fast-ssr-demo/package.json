{
  "name": "fast-ssr-demo",
  "scripts": {
    "build": "npm-run-all --parallel build:client build:server",
    "build:client": "vite build --config vite.config.js --mode client",
    "build:server": "vite build --config vite.config.js --mode server",
    "clean": "rm -rf dist public/hello-world.js",
    "dev": "node dist/server.js"
  },
  "type": "module",
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.10",
    "@microsoft/fast-element": "^2.10.1",
    "@microsoft/fast-ssr": "^1.0.0-beta.38",
    "hono": "^4.12.4"
  }
}
