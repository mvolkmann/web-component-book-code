{
  "name": "stencil-ssr-demo",
  "version": "0.0.1",
  "description": "Stencil Component Starter",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/stencil-ssr-demo/stencil-ssr-demo.esm.js",
  "exports": {
    ".": {
      "import": "./dist/stencil-ssr-demo/stencil-ssr-demo.esm.js",
      "require": "./dist/stencil-ssr-demo/stencil-ssr-demo.cjs.js"
    },
    "./my-component": {
      "types": "./dist/components/my-component.d.ts",
      "import": "./dist/components/my-component.js"
    },
    "./loader": {
      "types": "./loader/index.d.ts",
      "import": "./loader/index.js",
      "require": "./loader/index.cjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stenciljs/component-starter.git"
  },
  "files": [
    "dist/",
    "loader/"
  ],
  "scripts": {
    "build": "stencil build",
    "start": "stencil build --dev --watch --serve",
    "test": "stencil test --spec --e2e",
    "test.watch": "stencil test --spec --e2e --watchAll",
    "generate": "stencil generate",
    "build:server": "vite build",
    "dev": "node dist/server.mjs"
  },
  "devDependencies": {
    "@stencil/core": "^4.43.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.5",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "puppeteer": "^24.3.0",
    "vite": "^7.3.1"
  },
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.19.10",
    "hono": "^4.12.4"
  }
}
