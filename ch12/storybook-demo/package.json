{
  "name": "storybook-demo",
  "scripts": {
    "cem-local": "node ./custom-elements-manifest/packages/analyzer/cem.js analyze",
    "cem": "cem analyze --exclude 'coverage/**' 'custom-elements-manifest/**' 'src/stories/**' 'storybook-static/**'",
    "cem:watch": "cem analyze --watch",
    "deploy-storybook": "gh-pages -d storybook-static",
    "dev": "vite",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.1",
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/addon-vitest": "^10.3.4",
    "@storybook/web-components-vite": "^10.3.4",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "@wc-toolkit/storybook-helpers": "^10.2.1",
    "chromatic": "^16.1.0",
    "gh-pages": "^6.3.0",
    "playwright": "^1.59.1",
    "storybook": "^10.3.4",
    "storybook-addon-test-codegen": "^3.0.1",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "customElements": "custom-elements.json"
}
